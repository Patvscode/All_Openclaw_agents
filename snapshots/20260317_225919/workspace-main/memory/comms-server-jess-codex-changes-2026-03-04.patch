+    # Research Library methods
+    def _load_library(self):
+        if os.path.exists(LIBRARY_DIR + "/library.json"):
+            return json.load(open(LIBRARY_DIR + "/library.json"))
+        return {"items": []}
+
+    def _save_library(self, data):
+        os.makedirs(LIBRARY_DIR, exist_ok=True)
+        json.dump(data, open(LIBRARY_DIR + "/library.json", 'w'), indent=2)
+
+    def research_list_items(self, tag=None, limit=50):
+        data = self._load_library()
+        items = data.get("items", [])
+        if tag:
+            items = [i for i in items if tag in i.get("tags", [])]
+        return {"items": items[:limit]}
+
+    def research_search(self, query, tag=None, limit=20):
+        data = self._load_library()
+        items = data.get("items", [])
+        query_lower = query.lower()
+        results = []
+        for item in items:
+            text = (item.get("title", "") + " " + item.get("description", "") + " " + " ".join(item.get("tags", []))).lower()
+            if query_lower in text:
+                if tag is None or tag in item.get("tags", []):
+                    results.append(item)
+            if len(results) >= limit:
+                break
+        return {"items": results}
+
+    def research_get_item(self, item_id):
+        data = self._load_library()
+        items = data.get("items", [])
+        for item in items:
+            if item.get("id") == item_id:
+                return {"item": item}
+        return {"error": "Item not found"}
+
+    def research_save_item(self, body):
+        import uuid
+        data = self._load_library()
+        item = {
+            "id": uuid.uuid4().hex[:8],
+            "title": body.get("title", "Untitled"),
+            "url": body.get("url", ""),
+            "description": body.get("description", ""),
+            "tags": body.get("tags", []),
+            "notes": body.get("notes", ""),
+            "author": body.get("author", "unknown"),
+            "created": datetime.now().isoformat()
         }
+        data["items"].append(item)
+        self._save_library(data)
+        return {"ok": True, "item": item}
+
+    def research_update_item(self, body):
+        data = self._load_library()
+        items = data.get("items", [])
+        for item in items:
+            if item.get("id") == body.get("id"):
+                for k in ("title", "url", "description", "tags", "notes"):
+                    if k in body:
+                        item[k] = body[k]
+                item["updated"] = datetime.now().isoformat()
+                self._save_library(data)
+                return {"ok": True, "item": item}
+        return {"error": "Item not found"}
+
+    def research_delete_item(self, body):
+        data = self._load_library()
+        items = data.get("items", [])
+        items = [i for i in items if i.get("id") != body.get("id")]
+        data["items"] = items
+        self._save_library(data)
+        return {"ok": True}
