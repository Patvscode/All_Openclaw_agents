+
+function showAddResearch() {
+  const title = prompt('Title:');
+  if (!title) return;
+  const url = prompt('URL (optional):') || '';
+  const description = prompt('Description (optional):') || '';
+  const tags = prompt('Tags (comma-separated, optional):') || '';
+  const notes = prompt('Notes (optional):') || '';
+  
+  fetch(API + '/research', {
+    method: 'POST',
+    headers: {'Content-Type': 'application/json'},
+    body: JSON.stringify({
+      title, url, description,
+      tags: tags.split(',').map(t => t.trim()).filter(t => t),
+      notes
+    })
+  }).then(r => r.json()).then(data => {
+    if (data.ok) {
+      loadResearch();
+      closeResearchModal();
+    } else {
+      alert('Error adding item: ' + (data.error || 'Unknown error'));
+    }
+  }).catch(e => alert('Error: ' + e.message));
+}
+
+function deleteResearchItem(id) {
+  if (!confirm('Delete this research item?')) return;
+  fetch(API + '/research/delete', {
+    method: 'POST',
+    headers: {'Content-Type': 'application/json'},
+    body: JSON.stringify({id})
+  }).then(r => r.json()).then(data => {
+    if (data.ok) {
+      loadResearch();
+    } else {
+      alert('Error deleting item: ' + (data.error || 'Unknown error'));
+    }
+  }).catch(e => alert('Error: ' + e.message));
+}
