[Unit]
Description=Jess llama.cpp server (active model via symlink)
After=network.target

[Service]
Type=simple
ExecStart=/home/pmello/llama.cpp-new/build-cuda/bin/llama-server -m /home/pmello/models/active-model.gguf --host 127.0.0.1 --port 18080 --ctx-size 65536 --n-gpu-layers 999 --threads 16 --jinja --reasoning-format none --reasoning-budget 0
Restart=on-failure
RestartSec=10
WorkingDirectory=/home/pmello/.openclaw/workspace-q35

[Install]
WantedBy=default.target
